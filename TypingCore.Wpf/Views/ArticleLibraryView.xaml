<UserControl x:Class="TypingCore.Wpf.Views.ArticleLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="900">
    <UserControl.Resources>
        <!-- 搜索图标 -->
        <Geometry x:Key="SearchIcon">M10 4 C6.69 4 4 6.69 4 10 C4 13.31 6.69 16 10 16 C13.31 16 16 13.31 16 10 C16 6.69 13.31 4 10 4 Z M18 18 L14.5 14.5</Geometry>

        <!-- 面板卡片样式 -->
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#FAF8F5" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <!-- 主按钮样式 -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Margin" Value="0,12,0,0" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Background" Value="#8B5E3C" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBackground"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBackground" Property="Background" Value="#7A5234" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 次按钮样式 -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#8B5E3C" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#8B5E3C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBackground"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBackground" Property="Background" Value="#F0E6D6" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 输入框样式 -->
        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="38,0,12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#2D2926" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E8E2DA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="InputBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Grid>
                                <Path Width="18" Height="18"
                                      Margin="12,0,0,0"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Center"
                                      Stretch="Uniform"
                                      Stroke="#9A9088"
                                      StrokeThickness="1.5"
                                      StrokeEndLineCap="Round"
                                      StrokeStartLineCap="Round"
                                      Data="{StaticResource SearchIcon}" />
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="38,0,12,0"
                                              VerticalAlignment="Center"
                                              Focusable="False"
                                              HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Hidden" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="#8B5E3C" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 普通输入框样式 -->
        <Style x:Key="StandardTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#2D2926" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E8E2DA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="InputBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="#8B5E3C" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 下拉框样式 -->
        <Style x:Key="StandardComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#2D2926" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E8E2DA" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部说明面板 -->
        <Border Style="{StaticResource PanelBorderStyle}">
            <StackPanel>
                <TextBlock Text="文章导入与筛选"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#2D2926" />
                <TextBlock Margin="0,8,0,0"
                           Text="先在这里维护练习文章。文件导入和剪贴板导入都经过 Core 层的规范化流程，后续打字会话会直接消费这些记录。"
                           Foreground="#7A7067"
                           FontSize="13"
                           TextWrapping="Wrap"
                           LineHeight="20" />
                <TextBlock Margin="0,14,0,0"
                           Text="{Binding StatusMessage}"
                           Foreground="#8B5E3C"
                           FontSize="13"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- 搜索筛选行 -->
        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Style="{StaticResource SearchTextBoxStyle}"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

            <ComboBox Grid.Column="1"
                      Margin="12,0,0,0"
                      Style="{StaticResource StandardComboBoxStyle}"
                      ItemsSource="{Binding AvailableTags}"
                      SelectedItem="{Binding SelectedTag}" />

            <Button Grid.Column="2"
                    Margin="12,0,0,0"
                    Command="{Binding SearchCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="筛选" />

            <Button Grid.Column="3"
                    Margin="10,0,0,0"
                    Command="{Binding ClearFiltersCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Content="清空" />
        </Grid>

        <!-- 导入面板 -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="从文件导入"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#2D2926" />
                    <TextBlock Margin="0,6,0,0"
                               Text="支持选择文本文件，标题默认取文件名，标签可在下方一次性填写。"
                               Foreground="#7A7067"
                               FontSize="12"
                               TextWrapping="Wrap"
                               LineHeight="18" />
                    <TextBlock Margin="0,16,0,0"
                               Text="标签（用逗号分隔）"
                               Foreground="#7A7067"
                               FontSize="12"
                               FontWeight="SemiBold" />
                    <TextBox Margin="0,8,0,0"
                             Style="{StaticResource StandardTextBoxStyle}"
                             Text="{Binding ImportTagsText, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Command="{Binding ImportFromFileCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Content="选择文件并导入" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource PanelBorderStyle}" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="从剪贴板导入"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#2D2926" />
                    <TextBlock Margin="0,6,0,0"
                               Text="适合临时粘贴练习文本。导入时会先读取标题，再用 Core 导入服务做统一规范化。"
                               Foreground="#7A7067"
                               FontSize="12"
                               TextWrapping="Wrap"
                               LineHeight="18" />
                    <TextBlock Margin="0,16,0,0"
                               Text="标题"
                               Foreground="#7A7067"
                               FontSize="12"
                               FontWeight="SemiBold" />
                    <TextBox Margin="0,8,0,0"
                             Style="{StaticResource StandardTextBoxStyle}"
                             Text="{Binding ClipboardTitle, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Command="{Binding ImportFromClipboardCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Content="导入剪贴板文本" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- 文章列表 -->
        <ScrollViewer Grid.Row="3" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Articles}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,14"
                                Padding="20"
                                Background="#FFFFFF"
                                CornerRadius="14">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000"
                                                  BlurRadius="12"
                                                  ShadowDepth="2"
                                                  Opacity="0.06"
                                                  Direction="270" />
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- 左侧装饰条 -->
                                <Border Grid.Column="0"
                                        Background="#8B5E3C"
                                        CornerRadius="2"
                                        Margin="0,2,0,2" />

                                <Grid Grid.Column="1" Margin="14,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <DockPanel>
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   Foreground="#2D2926" />
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding CreatedAtText}"
                                                   Foreground="#9A9088"
                                                   FontSize="12" />
                                    </DockPanel>

                                    <TextBlock Grid.Row="1"
                                               Margin="0,8,0,0"
                                               Text="{Binding PreviewText}"
                                               Foreground="#5D544B"
                                               FontSize="13"
                                               TextWrapping="Wrap"
                                               LineHeight="20"
                                               MaxHeight="40" />

                                    <ItemsControl Grid.Row="2" Margin="0,12,0,0" ItemsSource="{Binding Tags}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,8,6"
                                                        Padding="10,4"
                                                        Background="#F0E6D6"
                                                        CornerRadius="999">
                                                    <TextBlock Text="{Binding}"
                                                               Foreground="#8B5E3C"
                                                               FontSize="11"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>