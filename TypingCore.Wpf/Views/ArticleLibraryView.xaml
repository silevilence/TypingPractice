<UserControl x:Class="TypingCore.Wpf.Views.ArticleLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="900">
    <UserControl.Resources>
        <!-- 搜索图标 -->
        <Geometry x:Key="SearchIcon">M10 4 C6.69 4 4 6.69 4 10 C4 13.31 6.69 16 10 16 C13.31 16 16 13.31 16 10 C16 6.69 13.31 4 10 4 Z M18 18 L14.5 14.5</Geometry>

        <!-- 面板卡片样式 -->
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PaperBackgroundBrush}" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="12" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Border Width="8"
                                    HorizontalAlignment="Center"
                                    Background="{DynamicResource TagBackgroundBrush}"
                                    CornerRadius="4"
                                    Opacity="0.55" />
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Focusable="False"
                                                  Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb MinHeight="42"
                                           Background="{DynamicResource AccentBrush}">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBackground"
                                                        Margin="2"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="4"
                                                        Opacity="0.75" />
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBackground" Property="Opacity" Value="0.95" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Focusable="False"
                                                  Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 主按钮样式 -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="28,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource OnAccentTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBackground"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBackground" Property="Background" Value="{DynamicResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="BtnBackground" Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                <Setter TargetName="BtnBackground" Property="BorderThickness" Value="1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 次按钮样式 -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="28,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBackground"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBackground" Property="Background" Value="{DynamicResource TagBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="BtnBackground" Property="Background" Value="{DynamicResource TagBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 输入框样式 -->
        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="38,0,12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="InputBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Grid>
                                <Path Width="18" Height="18"
                                      Margin="12,0,0,0"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Center"
                                      Stretch="Uniform"
                                      Stroke="{DynamicResource SecondaryTextBrush}"
                                      StrokeThickness="1.5"
                                      StrokeEndLineCap="Round"
                                      StrokeStartLineCap="Round"
                                      Data="{StaticResource SearchIcon}" />
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="38,0,12,0"
                                              VerticalAlignment="Center"
                                              Focusable="False"
                                              HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Hidden" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 普通输入框样式 -->
        <Style x:Key="StandardTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="InputBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 下拉箭头图标 -->
        <Geometry x:Key="ChevronDownIcon">M6 9 L12 15 L18 9</Geometry>

        <!-- 下拉框样式 -->
        <Style x:Key="StandardComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          Foreground="{DynamicResource PrimaryTextBrush}"
                                          BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ComboBorder"
                                                Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                CornerRadius="10"
                                                TextElement.Foreground="{DynamicResource PrimaryTextBrush}">
                                            <Grid>
                                                <ContentPresenter Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  TextElement.Foreground="{DynamicResource PrimaryTextBrush}"
                                                                  Margin="12,0,36,0"
                                                                  HorizontalAlignment="Left"
                                                                  VerticalAlignment="Center" />
                                                <Path Width="16" Height="16"
                                                      Margin="0,0,12,0"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Stretch="Uniform"
                                                      Stroke="{DynamicResource AccentBrush}"
                                                      StrokeThickness="1.5"
                                                      StrokeEndLineCap="Round"
                                                      StrokeStartLineCap="Round"
                                                      Data="{StaticResource ChevronDownIcon}" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,4,0,0"
                                        Padding="4"
                                        Background="{DynamicResource CardBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <ScrollViewer CanContentScroll="True"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="PART_Popup" Property="MinHeight" Value="0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBackground"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBackground" Property="Background" Value="{DynamicResource TagBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBackground" Property="Background" Value="{DynamicResource TagBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部说明面板 -->
        <Border Style="{StaticResource PanelBorderStyle}">
            <StackPanel>
                <TextBlock Text="文章导入与筛选"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}" />
                <TextBlock Margin="0,8,0,0"
                           Text="先在这里维护练习文章。文件导入和剪贴板导入都经过 Core 层的规范化流程，后续打字会话会直接消费这些记录。"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="13"
                           TextWrapping="Wrap"
                           LineHeight="20" />
                <TextBlock Margin="0,14,0,0"
                           Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource AccentBrush}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- 搜索筛选行 -->
        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Style="{StaticResource SearchTextBoxStyle}"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

            <ComboBox Grid.Column="1"
                      Margin="12,0,0,0"
                      Style="{StaticResource StandardComboBoxStyle}"
                      ItemsSource="{Binding AvailableTags}"
                      SelectedItem="{Binding SelectedTag}" />

            <ComboBox Grid.Column="2"
                      Margin="12,0,0,0"
                      Style="{StaticResource StandardComboBoxStyle}"
                      ItemsSource="{Binding SortOptions}"
                      SelectedItem="{Binding SelectedSortOption}" />

            <Button Grid.Column="3"
                    Margin="12,0,0,0"
                    Command="{Binding SearchCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="筛选" />

            <Button Grid.Column="4"
                    Margin="10,0,0,0"
                    Command="{Binding ClearFiltersCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Content="清空" />
        </Grid>

        <!-- 导入面板 -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="从文件导入"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock Margin="0,6,0,0"
                               Text="支持选择文本文件，标题默认取文件名，标签可在下方一次性填写。"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               LineHeight="18" />
                    <TextBlock Margin="0,16,0,0"
                               Text="标签（用逗号分隔）"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold" />
                    <TextBox Margin="0,8,0,0"
                             Style="{StaticResource StandardTextBoxStyle}"
                             Text="{Binding ImportTagsText, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Margin="0,12,0,0"
                            Command="{Binding ImportFromFileCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Content="选择文件并导入" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource PanelBorderStyle}" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="从剪贴板导入"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock Margin="0,6,0,0"
                               Text="适合临时粘贴练习文本。导入时会先读取标题，再用 Core 导入服务做统一规范化。"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               LineHeight="18" />
                    <TextBlock Margin="0,16,0,0"
                               Text="标题"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold" />
                    <TextBox Margin="0,8,0,0"
                             Style="{StaticResource StandardTextBoxStyle}"
                             Text="{Binding ClipboardTitle, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Margin="0,12,0,0"
                            Command="{Binding ImportFromClipboardCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Content="导入剪贴板文本" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- 文章列表 -->
        <ScrollViewer Grid.Row="3" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Articles}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,14"
                                Padding="20"
                                Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="14">
                            <Border.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="预览" Command="{Binding PreviewCommand}" />
                                    <MenuItem Header="编辑" Command="{Binding EditCommand}" />
                                    <Separator />
                                    <MenuItem Header="删除" Command="{Binding DeleteCommand}" />
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Border.Effect>
                                <DropShadowEffect Color="Black"
                                                  BlurRadius="12"
                                                  ShadowDepth="2"
                                                  Opacity="0.06"
                                                  Direction="270" />
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- 左侧装饰条 -->
                                <Border Grid.Column="0"
                                        Background="{DynamicResource AccentBrush}"
                                        CornerRadius="2"
                                        Margin="0,2,0,2" />

                                <Grid Grid.Column="1" Margin="14,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <DockPanel>
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding CreatedAtText}"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   FontSize="12" />
                                        <TextBlock DockPanel.Dock="Right"
                                                   Margin="0,0,14,0"
                                                   Text="{Binding WordCountText}"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   FontSize="12" />
                                    </DockPanel>

                                    <TextBlock Grid.Row="1"
                                               Margin="0,8,0,0"
                                               Text="{Binding PreviewText}"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               FontSize="13"
                                               TextWrapping="Wrap"
                                               LineHeight="20"
                                               MaxHeight="40" />

                                    <ItemsControl Grid.Row="2" Margin="0,12,0,0" ItemsSource="{Binding Tags}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Margin="0,0,8,6"
                                                        Padding="10,4"
                                                        Command="{Binding DataContext.FilterByTagCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Background="{DynamicResource TagBackgroundBrush}"
                                                        BorderBrush="Transparent"
                                                        BorderThickness="0"
                                                        Cursor="Hand">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    CornerRadius="999"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center" />
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                    <TextBlock Text="{Binding}"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold" />
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <StackPanel Grid.Row="3"
                                                Margin="0,14,0,0"
                                                Orientation="Horizontal">
                                        <Button Margin="0,0,10,0"
                                                Command="{Binding PreviewCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Content="预览" />
                                        <Button Margin="0,0,10,0"
                                                Command="{Binding EditCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Content="编辑" />
                                        <Button Margin="0,0,10,0"
                                                Command="{Binding DeleteCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Content="删除" />
                                        <Button Command="{Binding StartPracticeCommand}"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Content="开始练习" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.RowSpan="4"
              Panel.ZIndex="20"
              Background="Transparent">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDeleteConfirmationVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Width="420"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16">
                <Border.Effect>
                    <DropShadowEffect Color="Black"
                                      BlurRadius="16"
                                      ShadowDepth="2"
                                      Opacity="0.06"
                                      Direction="270" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="确认删除文章？"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock Margin="0,10,0,0"
                               Text="{Binding PendingDeleteTitle, StringFormat=删除后《{0}》将从文章库列表隐藏，可通过仓储恢复接口找回。}"
                               FontSize="14"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap"
                               LineHeight="22" />
                    <StackPanel Margin="0,20,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button Margin="0,0,10,0"
                                Command="{Binding CancelDeleteCommand}"
                                Content="取消"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Command="{Binding ConfirmDeleteCommand}"
                                Content="确认删除"
                                Style="{StaticResource PrimaryButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
