<UserControl x:Class="TypingCore.Wpf.Views.ArticleLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="900">
    <UserControl.Resources>
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#F7F1E7" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Margin" Value="0,12,0,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FFF8F1" />
            <Setter Property="Background" Value="#D0613A" />
            <Setter Property="BorderBrush" Value="#00000000" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PanelBorderStyle}">
            <StackPanel>
                <TextBlock Text="文章导入与筛选"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#2E2A24" />
                <TextBlock Margin="0,8,0,0"
                           Text="先在这里维护练习文章。文件导入和剪贴板导入都经过 Core 层的规范化流程，后续打字会话会直接消费这些记录。"
                           Foreground="#665C53"
                           TextWrapping="Wrap"
                           LineHeight="20" />
                <TextBlock Margin="0,14,0,0"
                           Text="{Binding StatusMessage}"
                           Foreground="#B6542C"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Height="40"
                     VerticalContentAlignment="Center"
                     Padding="12,0"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

            <ComboBox Grid.Column="1"
                      Margin="12,0,0,0"
                      Height="40"
                      Padding="8,0"
                      ItemsSource="{Binding AvailableTags}"
                      SelectedItem="{Binding SelectedTag}" />

            <Button Grid.Column="2"
                    Margin="12,0,0,0"
                    Padding="18,10"
                    Command="{Binding SearchCommand}"
                    Style="{StaticResource ActionButtonStyle}"
                    Content="筛选" />

            <Button Grid.Column="3"
                    Margin="10,0,0,0"
                    Padding="18,10"
                    Command="{Binding ClearFiltersCommand}"
                    Background="#8E7E6D"
                    Style="{StaticResource ActionButtonStyle}"
                    Content="清空" />
        </Grid>

        <Grid Grid.Row="2" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="从文件导入"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#2E2A24" />
                    <TextBlock Margin="0,8,0,0"
                               Text="支持选择文本文件，标题默认取文件名，标签可在下方一次性填写。"
                               Foreground="#665C53"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,18,0,0"
                               Text="标签（用逗号分隔）"
                               Foreground="#4E463E"
                               FontWeight="SemiBold" />
                    <TextBox Margin="0,8,0,0"
                             Height="38"
                             Padding="12,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding ImportTagsText, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Command="{Binding ImportFromFileCommand}"
                            Style="{StaticResource ActionButtonStyle}"
                            Content="选择文件并导入" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource PanelBorderStyle}" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="从剪贴板导入"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#2E2A24" />
                    <TextBlock Margin="0,8,0,0"
                               Text="适合临时粘贴练习文本。导入时会先读取标题，再用 Core 导入服务做统一规范化。"
                               Foreground="#665C53"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,18,0,0"
                               Text="标题"
                               Foreground="#4E463E"
                               FontWeight="SemiBold" />
                    <TextBox Margin="0,8,0,0"
                             Height="38"
                             Padding="12,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding ClipboardTitle, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Command="{Binding ImportFromClipboardCommand}"
                            Style="{StaticResource ActionButtonStyle}"
                            Content="导入剪贴板文本" />
                </StackPanel>
            </Border>
        </Grid>

        <ScrollViewer Grid.Row="3" Margin="0,18,0,0" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Articles}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,14"
                                Padding="20"
                                Background="#F8F4ED"
                                CornerRadius="18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <DockPanel>
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#2D2923" />
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding CreatedAtText}"
                                               Foreground="#8C8177" />
                                </DockPanel>

                                <TextBlock Grid.Row="1"
                                           Margin="0,10,0,0"
                                           Text="{Binding PreviewText}"
                                           Foreground="#5D544B"
                                           TextWrapping="Wrap"
                                           LineHeight="20" />

                                <ItemsControl Grid.Row="2" Margin="0,14,0,0" ItemsSource="{Binding Tags}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,8,8"
                                                    Padding="10,4"
                                                    Background="#E7DCCB"
                                                    CornerRadius="999">
                                                <TextBlock Text="{Binding}"
                                                           Foreground="#5A4D41"
                                                           FontSize="12"
                                                           FontWeight="SemiBold" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>