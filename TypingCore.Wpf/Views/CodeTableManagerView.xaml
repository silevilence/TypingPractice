<UserControl x:Class="TypingCore.Wpf.Views.CodeTableManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="900">
    <UserControl.Resources>
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#FAF8F5" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="28,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Background" Value="#8B5E3C" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#7A5234" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="28,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#8B5E3C" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#8B5E3C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#F0E6D6" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActivateButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Content" Value="启用" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Content" Value="已启用" />
                    <Setter Property="IsEnabled" Value="False" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PanelBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="码表导入与切换"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#2D2926" />
                    <TextBlock Margin="0,8,24,0"
                               Text="支持 code + 制表符 + word + 可选权重。文件开头的 YAML 头和 # 注释会被忽略。"
                               FontSize="13"
                               Foreground="#7A7067"
                               TextWrapping="Wrap"
                               LineHeight="20" />
                    <TextBlock Margin="0,12,24,0"
                               Text="{Binding StatusMessage}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#8B5E3C"
                               TextWrapping="Wrap" />
                </StackPanel>
                <Button Grid.Column="1"
                        VerticalAlignment="Top"
                        Command="{Binding ImportCommand}"
                        Content="导入码表"
                        Style="{StaticResource PrimaryButtonStyle}" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <TextBlock HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Text="尚未导入码表"
                       FontSize="14"
                       Foreground="#7A7067">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasCodeTables}" Value="False">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding CodeTables}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,14"
                                    Padding="20"
                                    Background="#FFFFFF"
                                    BorderBrush="#E8E2DA"
                                    BorderThickness="1"
                                    CornerRadius="14">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000"
                                                      BlurRadius="14"
                                                      ShadowDepth="2"
                                                      Opacity="0.06"
                                                      Direction="270" />
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#8B5E3C"
                                            CornerRadius="2" />
                                    <StackPanel Grid.Column="1" Margin="14,0,20,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Foreground="#2D2926" />
                                            <Border Margin="10,0,0,0"
                                                    Padding="10,4"
                                                    Background="#F0E6D6"
                                                    CornerRadius="999">
                                                <TextBlock FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="#8B5E3C">
                                                    <Run Text="{Binding EntryCount, Mode=OneWay}" />
                                                    <Run Text=" 条" />
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="{Binding Source}"
                                                   FontSize="12"
                                                   Foreground="#7A7067"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding LoadedAtText, StringFormat=导入时间：{0}}"
                                                   FontSize="12"
                                                   Foreground="#7A7067" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Margin="0,0,10,0"
                                                Command="{Binding ActivateCommand}"
                                                Style="{StaticResource ActivateButtonStyle}" />
                                        <Button Command="{Binding DeleteCommand}"
                                                Content="删除"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
