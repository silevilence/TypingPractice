<UserControl x:Class="TypingCore.Wpf.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="900">
    <UserControl.Resources>
        <Style x:Key="SettingsCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FAF8F5" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="22" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <!-- 下拉箭头图标 -->
        <Geometry x:Key="ChevronDownIcon">M6 9 L12 15 L18 9</Geometry>

        <Style x:Key="SettingsComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#2D2926" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E8E2DA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border x:Name="ComboBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Grid>
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  Margin="12,0,36,0"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center" />
                                <Path Width="16" Height="16"
                                      Margin="0,0,12,0"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Stretch="Uniform"
                                      Stroke="#8B5E3C"
                                      StrokeThickness="1.5"
                                      StrokeEndLineCap="Round"
                                      StrokeStartLineCap="Round"
                                      Data="{StaticResource ChevronDownIcon}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#8B5E3C" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#8B5E3C" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource SettingsCardStyle}">
            <StackPanel>
                <TextBlock Text="设置页框架"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#2D2926" />
                <TextBlock Margin="0,8,0,0"
                           Text="{Binding Description}"
                           Foreground="#7A7067"
                           FontSize="13"
                           TextWrapping="Wrap"
                           LineHeight="20" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SettingsCardStyle}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="主题"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#2D2926" />
                    <TextBlock Margin="0,6,0,0"
                               Text="阶段七先保留选项清单，阶段十三再接入持久化和运行时切换。"
                               Foreground="#7A7067"
                               FontSize="12"
                               TextWrapping="Wrap"
                               LineHeight="18" />
                    <ComboBox Margin="0,16,0,0"
                              Style="{StaticResource SettingsComboBoxStyle}"
                              ItemsSource="{Binding ThemeOptions}"
                              SelectedItem="{Binding SelectedTheme, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource SettingsCardStyle}" Margin="10,0">
                <StackPanel>
                    <TextBlock Text="字体"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#2D2926" />
                    <TextBlock Margin="0,6,0,0"
                               Text="先给出计划中的默认字族，后续再把字号和布局联动加进来。"
                               Foreground="#7A7067"
                               FontSize="12"
                               TextWrapping="Wrap"
                               LineHeight="18" />
                    <ComboBox Margin="0,16,0,0"
                              Style="{StaticResource SettingsComboBoxStyle}"
                              ItemsSource="{Binding FontOptions}"
                              SelectedItem="{Binding SelectedFont, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource SettingsCardStyle}" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="快捷键"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#2D2926" />
                    <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding ShortcutHints}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="12"
                                        Background="#F0E6D6"
                                        CornerRadius="10">
                                    <TextBlock Text="{Binding}"
                                               TextWrapping="Wrap"
                                               Foreground="#7A6650"
                                               FontSize="12"
                                               LineHeight="18" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>