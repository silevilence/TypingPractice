<UserControl x:Class="TypingCore.Wpf.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="900">
    <UserControl.Resources>
        <Style x:Key="SettingsCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#F7F1E7" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="22" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource SettingsCardStyle}">
            <StackPanel>
                <TextBlock Text="设置页框架"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#2E2A24" />
                <TextBlock Margin="0,10,0,0"
                           Text="{Binding Description}"
                           Foreground="#665C53"
                           TextWrapping="Wrap"
                           LineHeight="20" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SettingsCardStyle}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="主题"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#2E2A24" />
                    <TextBlock Margin="0,8,0,0"
                               Text="阶段七先保留选项清单，阶段十三再接入持久化和运行时切换。"
                               Foreground="#665C53"
                               TextWrapping="Wrap" />
                    <ComboBox Margin="0,18,0,0"
                              Height="40"
                              Padding="8,0"
                              ItemsSource="{Binding ThemeOptions}"
                              SelectedItem="{Binding SelectedTheme, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource SettingsCardStyle}" Margin="10,0">
                <StackPanel>
                    <TextBlock Text="字体"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#2E2A24" />
                    <TextBlock Margin="0,8,0,0"
                               Text="先给出计划中的默认字族，后续再把字号和布局联动加进来。"
                               Foreground="#665C53"
                               TextWrapping="Wrap" />
                    <ComboBox Margin="0,18,0,0"
                              Height="40"
                              Padding="8,0"
                              ItemsSource="{Binding FontOptions}"
                              SelectedItem="{Binding SelectedFont, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource SettingsCardStyle}" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="快捷键"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#2E2A24" />
                    <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding ShortcutHints}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        Background="#EFE4D4"
                                        CornerRadius="14">
                                    <TextBlock Text="{Binding}"
                                               TextWrapping="Wrap"
                                               Foreground="#5A5047"
                                               LineHeight="19" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>