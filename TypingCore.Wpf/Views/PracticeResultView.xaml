<UserControl x:Class="TypingCore.Wpf.Views.PracticeResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="900">
    <UserControl.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="28,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource OnAccentTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="{DynamicResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="{DynamicResource TagBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Margin" Value="7" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black"
                                      BlurRadius="14"
                                      ShadowDepth="2"
                                      Opacity="0.06"
                                      Direction="270" />
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource PaperBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="22,22,22,8">
            <TextBlock Text="本次练习完成"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource SuccessBrush}" />
            <TextBlock Margin="0,8,0,0"
                       Text="{Binding ArticleTitle}"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryTextBrush}" />
            <TextBlock Margin="0,8,0,0"
                       Text="结果已保存，可重练当前文章或查看历史趋势。"
                       FontSize="14"
                       Foreground="{DynamicResource SecondaryTextBrush}" />
        </StackPanel>

        <UniformGrid Grid.Row="1"
                     Margin="15,8"
                     Columns="4">
            <Border Style="{StaticResource MetricCardStyle}">
                <StackPanel>
                    <TextBlock Text="键速 KPM" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding KeystrokesPerMinute, StringFormat={}{0:0}}"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCardStyle}">
                <StackPanel>
                    <TextBlock Text="字速 CPM" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding CharactersPerMinute, StringFormat={}{0:0}}"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCardStyle}">
                <StackPanel>
                    <TextBlock Text="英文 WPM" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding WordsPerMinute, StringFormat={}{0:0.0}}"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCardStyle}">
                <StackPanel>
                    <TextBlock Text="平均码长" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding AverageCodeLength, StringFormat={}{0:0.00}}"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCardStyle}">
                <StackPanel>
                    <TextBlock Text="错误字符" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding ErrorCharacterCount}"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{DynamicResource ErrorBrush}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCardStyle}">
                <StackPanel>
                    <TextBlock Text="错误率" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding ErrorRate, StringFormat={}{0:P1}}"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{DynamicResource ErrorBrush}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCardStyle}">
                <StackPanel>
                    <TextBlock Text="退格次数" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding BackspaceCount}"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCardStyle}">
                <StackPanel>
                    <TextBlock Text="总耗时" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding ElapsedText}"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <StackPanel Grid.Row="2"
                    Margin="22,8,22,22"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Margin="0,0,10,0"
                    Command="{Binding RetryCommand}"
                    Content="再练一次"
                    Style="{StaticResource PrimaryButtonStyle}" />
            <Button Margin="0,0,10,0"
                    Command="{Binding ShowHistoryCommand}"
                    Content="查看历史"
                    Style="{StaticResource SecondaryButtonStyle}" />
            <Button Command="{Binding ReturnToLibraryCommand}"
                    Content="返回文章库"
                    Style="{StaticResource SecondaryButtonStyle}" />
        </StackPanel>
    </Grid>
</UserControl>
