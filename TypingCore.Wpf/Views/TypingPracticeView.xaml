<UserControl x:Class="TypingCore.Wpf.Views.TypingPracticeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:TypingCore.Wpf.Views"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="900"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded">
    <UserControl.Resources>
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PaperBackgroundBrush}" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="22" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="28,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource OnAccentTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBackground"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBackground" Property="Background" Value="{DynamicResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="28,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBackground"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBackground" Property="Background" Value="{DynamicResource TagBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PracticeCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black"
                                      BlurRadius="14"
                                      ShadowDepth="2"
                                      Opacity="0.06"
                                      Direction="270" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InterleavedLayoutButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SecondaryButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsInterleavedLayout}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TagBackgroundBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FollowingLayoutButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SecondaryButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFollowingLayout}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TagBackgroundBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InterleavedLayoutContainerStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsInterleavedLayout}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FollowingLayoutContainerStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFollowingLayout}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border x:Name="InputSurface"
            Background="Transparent"
            Cursor="IBeam"
            Focusable="False"
            PreviewMouseLeftButtonDown="InputSurface_PreviewMouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Padding="18"
                    Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding ArticleTitle}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding StatusMessage}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   LineHeight="18" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Top">
                        <Button Margin="0,0,10,0"
                                Command="{Binding PauseCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="{Binding PauseButtonText}" />
                        <Button Margin="0,0,10,0"
                                Command="{Binding RestartCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Content="重新开始" />
                        <Button Command="{Binding ReturnToLibraryCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="返回文章库" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,12,0,0"
                    Padding="18,12"
                    Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock VerticalAlignment="Center"
                                   Text="进度"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}" />
                        <TextBlock Margin="14,0,0,0"
                                   Text="{Binding ProgressText}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock VerticalAlignment="Center"
                                   Text="键速"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}" />
                        <TextBlock Margin="14,0,0,0"
                                   Text="{Binding KeystrokesPerMinute, StringFormat={}{0:0}}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock VerticalAlignment="Center"
                                   Text="字速"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}" />
                        <TextBlock Margin="14,0,0,0"
                                   Text="{Binding CharactersPerMinute, StringFormat={}{0:0}}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </StackPanel>

                    <StackPanel Grid.Column="3"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock VerticalAlignment="Center"
                                   Text="码长"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}" />
                        <TextBlock Margin="14,0,0,0"
                                   Text="{Binding AverageCodeLength, StringFormat={}{0:0.00}}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </StackPanel>

                    <StackPanel Grid.Column="4"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock VerticalAlignment="Center"
                                   Text="错误"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}" />
                        <TextBlock Margin="14,0,0,0"
                                   Text="{Binding ErrorCharacterCount}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource ErrorBrush}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Margin="0,12,0,0"
                    Padding="18"
                    Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center"
                                   Text="练习布局"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Margin="0,0,10,0"
                                    Command="{Binding SelectInterleavedLayoutCommand}"
                                    Style="{StaticResource InterleavedLayoutButtonStyle}"
                                    Content="布局 A · 逐字对齐" />
                            <Button Command="{Binding SelectFollowingLayoutCommand}"
                                    Style="{StaticResource FollowingLayoutButtonStyle}"
                                    Content="布局 B · 上下跟随" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid Style="{StaticResource InterleavedLayoutContainerStyle}">
                            <ScrollViewer x:Name="PracticeScrollViewer"
                                          Focusable="False"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          CanContentScroll="False"
                                          VerticalAlignment="Stretch">
                                <views:InterleavedTypingRenderControl MinHeight="220"
                                                                      HorizontalAlignment="Stretch"
                                                                      VerticalAlignment="Top"
                                                                      ArticleLayout="{Binding ArticleLayout}"
                                                                      CharacterSnapshots="{Binding CharacterSnapshots}"
                                                                      CurrentTextIndex="{Binding CurrentTextIndex}"
                                                                      FontFamily="{Binding PracticeFontFamily}"
                                                                      FontSize="{Binding PracticeFontSize}" />
                            </ScrollViewer>
                        </Grid>

                        <Grid Style="{StaticResource FollowingLayoutContainerStyle}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="14" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource PracticeCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="原文跟随"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                    <ScrollViewer x:Name="FollowingTargetScrollViewer"
                                                  Grid.Row="1"
                                                  Margin="0,12,0,0"
                                                  Focusable="False"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <views:FollowingTypingTextBlock CharacterSnapshots="{Binding CharacterSnapshots}"
                                                                        FontFamily="{Binding PracticeFontFamily}"
                                                                        FontSize="{Binding PracticeFontSize}"
                                                                        TextWrapping="Wrap" />
                                    </ScrollViewer>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" Style="{StaticResource PracticeCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="自由输入"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                    <ScrollViewer x:Name="FollowingInputScrollViewer"
                                                  Grid.Row="1"
                                                  Margin="0,12,0,0"
                                                  Focusable="False"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <Grid>
                                            <TextBlock Text="{Binding CommittedText, NotifyOnTargetUpdated=True}"
                                                       TargetUpdated="FollowingInputText_TargetUpdated"
                                                       MinHeight="54"
                                                       FontFamily="{Binding PracticeFontFamily}"
                                                       FontSize="{Binding PracticeFontSize}"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock IsHitTestVisible="False"
                                                       Text="已上屏内容会在这里连续展示"
                                                       FontSize="14"
                                                       Foreground="{DynamicResource SecondaryTextBrush}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CommittedText}" Value="">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>

                        <TextBox x:Name="ImeInputSink"
                                 Width="1"
                                 Height="1"
                                 Margin="8,8,0,0"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Top"
                                 IsHitTestVisible="False"
                                 Opacity="0"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 CaretBrush="Transparent"
                                 FocusVisualStyle="{x:Null}"
                                 Foreground="Transparent"
                                 IsUndoEnabled="False"
                                 InputMethod.IsInputMethodEnabled="True"
                                 InputMethod.PreferredImeState="On" />
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Panel.ZIndex="10"
                    Width="260"
                    Margin="0,0,36,20"
                    Padding="16"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14">
                <Border.Effect>
                    <DropShadowEffect Color="Black"
                                      BlurRadius="14"
                                      ShadowDepth="2"
                                      Opacity="0.06"
                                      Direction="270" />
                </Border.Effect>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasCodeHints}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="编码提示"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <ItemsControl Margin="0,10,0,0"
                                  ItemsSource="{Binding CodeHints}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Padding="10,4"
                                            Background="{DynamicResource TagBackgroundBrush}"
                                            CornerRadius="999">
                                        <TextBlock Text="{Binding SourceText}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AccentBrush}" />
                                    </Border>
                                    <ItemsControl Grid.Column="1"
                                                  Margin="10,0,0,0"
                                                  VerticalAlignment="Center"
                                                  ItemsSource="{Binding CandidateCodes}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Margin="0,0,10,0"
                                                           Text="{Binding}"
                                                           FontFamily="Consolas"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource PrimaryTextBrush}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Grid Grid.RowSpan="3"
                  Panel.ZIndex="30"
                  Background="Transparent">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRestartConfirmationVisible}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Border Width="420"
                        Padding="24"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16">
                    <Border.Effect>
                        <DropShadowEffect Color="Black"
                                          BlurRadius="16"
                                          ShadowDepth="2"
                                          Opacity="0.06"
                                          Direction="270" />
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="确认重新开始？"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                        <TextBlock Margin="0,10,0,0"
                                   Text="当前进度和本次实时统计将被清空。连续按 Esc 只会取消，不会确认。"
                                   FontSize="14"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   LineHeight="22" />
                        <StackPanel Margin="0,20,0,0"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal">
                            <Button Margin="0,0,10,0"
                                    Command="{Binding CancelRestartCommand}"
                                    Content="取消"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Command="{Binding ConfirmRestartCommand}"
                                    Content="确认重新开始"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

        </Grid>
    </Border>
</UserControl>
