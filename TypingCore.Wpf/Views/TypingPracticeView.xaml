<UserControl x:Class="TypingCore.Wpf.Views.TypingPracticeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:TypingCore.Wpf.Views"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="900"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded">
    <UserControl.Resources>
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#FAF8F5" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="22" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="28,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Background" Value="#8B5E3C" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBackground"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBackground" Property="Background" Value="#7A5234" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="28,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#8B5E3C" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#8B5E3C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBackground"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBackground" Property="Background" Value="#F0E6D6" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,14,0" />
        </Style>
    </UserControl.Resources>

        <Border x:Name="InputSurface"
            Background="Transparent"
            Cursor="IBeam"
            Focusable="False"
            PreviewMouseLeftButtonDown="InputSurface_PreviewMouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="练习输入已接通"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#2D2926" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding ArticleTitle}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#8B5E3C" />
                        <TextBlock Margin="0,12,0,0"
                                   Text="{Binding StatusMessage}"
                                   Foreground="#7A7067"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   LineHeight="20" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Top">
                        <Button Margin="0,0,10,0"
                                Command="{Binding RestartCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Content="重新开始" />
                        <Button Command="{Binding ReturnToLibraryCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="返回文章库" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="进度"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#8B5E3C" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding ProgressText}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#2D2926" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="正确字数"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#8B5E3C" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding CorrectCharacterCount}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#2D2926" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}" Margin="0">
                    <StackPanel>
                        <TextBlock Text="错误字数"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#8B5E3C" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding ErrorCharacterCount}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#2D2926" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Margin="0,16,0,0" Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="逐字对齐练习区"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#2D2926" />
                    <TextBlock Grid.Row="1"
                               Margin="0,10,0,0"
                               Text="上行显示原文，下行显示已上屏内容；当前字符会高亮，错误输入直接标红。"
                               Foreground="#7A7067"
                               FontSize="13"
                               TextWrapping="Wrap"
                               LineHeight="22" />
                    <Grid Grid.Row="2" Margin="0,14,0,0">
                        <ScrollViewer x:Name="PracticeScrollViewer"
                                      Focusable="False"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="False"
                                      VerticalAlignment="Stretch">
                            <views:InterleavedTypingRenderControl MinHeight="220"
                                                                  HorizontalAlignment="Stretch"
                                                                  VerticalAlignment="Top"
                                                                  ArticleLayout="{Binding ArticleLayout}"
                                                                  CharacterSnapshots="{Binding CharacterSnapshots}"
                                                                  CurrentTextIndex="{Binding CurrentTextIndex}"
                                                                  FontSize="18" />
                        </ScrollViewer>
                        <TextBox x:Name="ImeInputSink"
                                 Width="1"
                                 Height="1"
                                 Margin="8,8,0,0"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Top"
                                 IsHitTestVisible="False"
                                 Opacity="0"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 CaretBrush="Transparent"
                                 FocusVisualStyle="{x:Null}"
                                 Foreground="Transparent"
                                 IsUndoEnabled="False"
                                 InputMethod.IsInputMethodEnabled="True"
                                 InputMethod.PreferredImeState="On" />
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="3" Margin="0,16,0,0" Style="{StaticResource PanelBorderStyle}">
                <StackPanel>
                    <TextBlock Text="输入说明"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#2D2926" />
                    <TextBlock Margin="0,10,0,0"
                               Text="本页会直接监听窗口键盘消息和输入法上屏内容。切到这里后可直接输入；Backspace 删除已上屏字符，Esc 重新开始，方向键暂时只显示提示。"
                               Foreground="#7A7067"
                               FontSize="13"
                               TextWrapping="Wrap"
                               LineHeight="22" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>