<UserControl x:Class="TypingCore.Wpf.Views.TypingPracticeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:TypingCore.Wpf.Views"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="900"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded">
    <UserControl.Resources>
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#FAF8F5" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="22" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="28,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Background" Value="#8B5E3C" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBackground"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBackground" Property="Background" Value="#7A5234" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="28,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#8B5E3C" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#8B5E3C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBackground"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBackground" Property="Background" Value="#F0E6D6" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PracticeCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E8E2DA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black"
                                      BlurRadius="14"
                                      ShadowDepth="2"
                                      Opacity="0.06"
                                      Direction="270" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InterleavedLayoutButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SecondaryButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsInterleavedLayout}" Value="True">
                    <Setter Property="Background" Value="#F0E6D6" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FollowingLayoutButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SecondaryButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFollowingLayout}" Value="True">
                    <Setter Property="Background" Value="#F0E6D6" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InterleavedLayoutContainerStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsInterleavedLayout}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FollowingLayoutContainerStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFollowingLayout}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border x:Name="InputSurface"
            Background="Transparent"
            Cursor="IBeam"
            Focusable="False"
            PreviewMouseLeftButtonDown="InputSurface_PreviewMouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Padding="18"
                    Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding ArticleTitle}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#2D2926" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding StatusMessage}"
                                   Foreground="#7A7067"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   LineHeight="18" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Top">
                        <Button Margin="0,0,10,0"
                                Command="{Binding RestartCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Content="重新开始" />
                        <Button Command="{Binding ReturnToLibraryCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="返回文章库" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,12,0,0"
                    Padding="18,12"
                    Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock VerticalAlignment="Center"
                                   Text="进度"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#8B5E3C" />
                        <TextBlock Margin="14,0,0,0"
                                   Text="{Binding ProgressText}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#2D2926" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock VerticalAlignment="Center"
                                   Text="正确"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#8B5E3C" />
                        <TextBlock Margin="14,0,0,0"
                                   Text="{Binding CorrectCharacterCount}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#2D2926" />
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock VerticalAlignment="Center"
                                   Text="错误"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#8B5E3C" />
                        <TextBlock Margin="14,0,0,0"
                                   Text="{Binding ErrorCharacterCount}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#2D2926" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Margin="0,12,0,0"
                    Padding="18"
                    Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center"
                                   Text="练习布局"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#2D2926" />

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Margin="0,0,10,0"
                                    Command="{Binding SelectInterleavedLayoutCommand}"
                                    Style="{StaticResource InterleavedLayoutButtonStyle}"
                                    Content="布局 A · 逐字对齐" />
                            <Button Command="{Binding SelectFollowingLayoutCommand}"
                                    Style="{StaticResource FollowingLayoutButtonStyle}"
                                    Content="布局 B · 上下跟随" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid Style="{StaticResource InterleavedLayoutContainerStyle}">
                            <ScrollViewer x:Name="PracticeScrollViewer"
                                          Focusable="False"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          CanContentScroll="False"
                                          VerticalAlignment="Stretch">
                                <views:InterleavedTypingRenderControl MinHeight="220"
                                                                      HorizontalAlignment="Stretch"
                                                                      VerticalAlignment="Top"
                                                                      ArticleLayout="{Binding ArticleLayout}"
                                                                      CharacterSnapshots="{Binding CharacterSnapshots}"
                                                                      CurrentTextIndex="{Binding CurrentTextIndex}"
                                                                      FontSize="18" />
                            </ScrollViewer>
                        </Grid>

                        <Grid Style="{StaticResource FollowingLayoutContainerStyle}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="14" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource PracticeCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="原文跟随"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="#2D2926" />
                                    <ScrollViewer x:Name="FollowingTargetScrollViewer"
                                                  Grid.Row="1"
                                                  Margin="0,12,0,0"
                                                  Focusable="False"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <views:FollowingTypingTextBlock CharacterSnapshots="{Binding CharacterSnapshots}"
                                                                        FontSize="18"
                                                                        LineHeight="27"
                                                                        TextWrapping="Wrap" />
                                    </ScrollViewer>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" Style="{StaticResource PracticeCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="自由输入"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="#2D2926" />
                                    <ScrollViewer x:Name="FollowingInputScrollViewer"
                                                  Grid.Row="1"
                                                  Margin="0,12,0,0"
                                                  Focusable="False"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <Grid>
                                            <TextBlock Text="{Binding CommittedText, NotifyOnTargetUpdated=True}"
                                                       TargetUpdated="FollowingInputText_TargetUpdated"
                                                       MinHeight="54"
                                                       FontSize="18"
                                                       LineHeight="27"
                                                       Foreground="#2D2926"
                                                       TextWrapping="Wrap" />
                                            <TextBlock IsHitTestVisible="False"
                                                       Text="已上屏内容会在这里连续展示"
                                                       FontSize="14"
                                                       Foreground="#7A7067">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CommittedText}" Value="">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>

                        <TextBox x:Name="ImeInputSink"
                                 Width="1"
                                 Height="1"
                                 Margin="8,8,0,0"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Top"
                                 IsHitTestVisible="False"
                                 Opacity="0"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 CaretBrush="Transparent"
                                 FocusVisualStyle="{x:Null}"
                                 Foreground="Transparent"
                                 IsUndoEnabled="False"
                                 InputMethod.IsInputMethodEnabled="True"
                                 InputMethod.PreferredImeState="On" />
                    </Grid>
                </Grid>
            </Border>

        </Grid>
    </Border>
</UserControl>
